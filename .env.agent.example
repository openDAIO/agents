# Per-agent environment. Copy this file to .env.agent_1, .env.agent_2, etc.
# Each independent reviewer/operator should own exactly one such file.

# Chain / deployment
# Public Sepolia RPC for quick start. Replace with a dedicated provider for
# production traffic.
RPC_URL=https://sepolia.drpc.org
# Optional comma- or space-separated fallback RPC endpoints. RPC_URL is always
# tried first and duplicate URLs are ignored.
RPC_URLS=https://ethereum-sepolia-rpc.publicnode.com,https://1rpc.io/sepolia,https://rpc.sepolia.ethpandaops.io,https://sepolia.gateway.tenderly.co
RPC_FAILOVER_STALL_TIMEOUT_MS=750
RPC_FAILOVER_QUORUM=1
RPC_FAILOVER_EVENT_QUORUM=1
RPC_FAILOVER_EVENT_WORKERS=3
RPC_FAILOVER_CACHE_TIMEOUT_MS=250
RPC_BATCH_MAX_COUNT=1
RPC_READ_RETRIES=5
RPC_READ_RETRY_BASE_MS=500
RPC_TX_WAIT_RETRIES=8
RPC_TX_WAIT_RETRY_BASE_MS=1000
DAIO_DEPLOYMENT_FILE=sepolia.json
# Alternative to ./.deployments/sepolia.json:
# DAIO_DEPLOYMENT_JSON_B64=

# Content API used by this agent.
# In the bundled docker-compose.yml, this is overridden to http://content-service:18002.
CONTENT_SERVICE_URL=http://127.0.0.1:18002

# LLM (OpenAI GPT API by default, OpenAI-compatible fallback supported)
# When OPENAI_API_KEY is set, the runtime defaults to https://api.openai.com/v1.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5-2026-04-23
# Optional override for proxies or compatible gateways.
# OPENAI_BASE_URL=https://api.openai.com/v1
# Optional override. By default the runtime derives a stable key from the shared prompt prefix.
# OPENAI_PROMPT_CACHE_KEY=
OPENAI_PROMPT_CACHE_RETENTION=24h
# Legacy/OpenAI-compatible endpoint fallback when OPENAI_API_KEY is not set.
LLM_BASE_URL=
LLM_MODEL=
LLM_TIMEOUT_MS=120000
LLM_MAX_TOKENS=8192
LLM_PROPOSAL_CHAR_BUDGET=16000
# Leave blank with OpenAI GPT API to use the model default reasoning level.
LLM_REASONING_EFFORT=
LLM_RESPONSE_CACHE_TTL_SECONDS=0
LLM_RESPONSE_CACHE_MAX_ENTRIES=4096
LLM_RESPONSE_CACHE_DB_PATH=
DAIO_TX_FINALITY_CONFIRMATIONS=1
DAIO_TX_FINALITY_WAIT_TIMEOUT_MS=300000
# Optional EIP-1559 fee overrides for faster demo tx inclusion.
# If DAIO_TX_MAX_FEE_GWEI is blank, runtime uses 2 * latest baseFee + priority fee.
DAIO_TX_PRIORITY_FEE_GWEI=
DAIO_TX_MAX_FEE_GWEI=
# Optional sampling temperature for LLM calls (0..1). Higher values produce more
# variation between runs and between independent reviewers. Defaults to 0.
# LLM_TEMPERATURE=0.3

# Optional reviewer persona text injected into the LLM system prompt. This is
# what makes independent agents disagree naturally instead of producing the
# same JSON every time. Keep it short and focused on what to weight / how
# strict to be; do NOT alter the output schema or score scale here.
# AGENT_PERSONA=Methodologist persona. You weight statistical rigor, reproducibility, and ablations heavily; score conservatively.
# Optional task-specific overlays appended after AGENT_PERSONA:
# AGENT_REVIEW_STYLE=
# AGENT_AUDIT_STYLE=

# Reviewer identity and local secrets.
# Use different values for every independent agent.
# Generate AGENT_STATE_KEY with: openssl rand -hex 32
# Generate AGENT_VRF_PRIVATE_KEY with: openssl rand -hex 32
AGENT_STATE_KEY=
AGENT_PRIVATE_KEY=
AGENT_VRF_PRIVATE_KEY=
AGENT_LABEL=R1
AGENT_STATE_DIR=./.state/agent-1
AGENT_ID=1001
AGENT_ENS_NAME=reviewer-1.daio.eth
AGENT_AUTO_REGISTER=true
# Set false when the configured ENS name does not resolve to this reviewer or
# ERC-8004 agent wallet on the active chain.
DAIO_REGISTER_ENS=false
DAIO_AGENT_TARGET_STAKE_USDAIO=6000

# Local fallback only. Agents prefer DAIOCore's on-chain storage config.
DAIO_REVIEW_ELECTION_DIFFICULTY=8000
DAIO_AUDIT_ELECTION_DIFFICULTY=10000
DAIO_AUDIT_TARGET_LIMIT=2
DAIO_AUTO_START_REQUESTS=true
DAIO_KEEPER_ENABLED=false
# Optional for a keeper-enabled process. If omitted, keeper txs use
# AGENT_PRIVATE_KEY. Review/audit txs always use AGENT_PRIVATE_KEY.
DAIO_KEEPER_PRIVATE_KEY=
DAIO_KEEPER_RECONCILE_INTERVAL_MS=10000
DAIO_KEEPER_SYNC_ACTIVE_REQUESTS=true
DAIO_KEEPER_SYNC_MAX_PER_TICK=8
DAIO_START_NEXT_REQUEST_GAS_FLOOR=300000
DAIO_SYNC_REQUEST_GAS_FLOOR=2000000
DAIO_START_REQUESTS_MAX_PER_TICK=2
DAIO_START_REQUESTS_MIN_INTERVAL_MS=1000
DAIO_START_REQUESTS_JITTER_MS=250
DAIO_DOCUMENT_WAIT_MS=300000
DAIO_DOCUMENT_RETRY_INITIAL_MS=1000
DAIO_DOCUMENT_RETRY_MAX_MS=10000
DAIO_DOCUMENT_RECHECK_MS=10000
DAIO_MIN_COMMIT_TIME_REMAINING_MS=120000
DAIO_FALLBACK_PHASE_TIMEOUT_MS=600000
DAIO_EVENT_LOOKBACK_BLOCKS=7200
DAIO_EVENT_REORG_DEPTH_BLOCKS=12
DAIO_ALLOW_FIXTURE_VRF=false

# Optional but recommended for Sepolia/fork stability. When set, agents skip
# expensive gas estimation and use these transaction gas limits.
DAIO_REVIEW_COMMIT_GAS_FLOOR=7000000
DAIO_REVIEW_REVEAL_GAS_FLOOR=2000000
DAIO_AUDIT_COMMIT_GAS_FLOOR=12000000
DAIO_AUDIT_REVEAL_GAS_FLOOR=12000000
