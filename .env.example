# Production Sepolia chain / deployment
# Public Sepolia RPC for quick start and E2E. Replace with a dedicated provider
# for production traffic.
RPC_URL=https://sepolia.drpc.org
# Optional comma- or space-separated fallback RPC endpoints. RPC_URL is always
# tried first and duplicate URLs are ignored.
RPC_URLS=https://sepolia.drpc.org,https://ethereum-sepolia-rpc.publicnode.com
RPC_FAILOVER_STALL_TIMEOUT_MS=750
RPC_FAILOVER_QUORUM=1
RPC_FAILOVER_EVENT_QUORUM=1
RPC_FAILOVER_EVENT_WORKERS=2
RPC_FAILOVER_CACHE_TIMEOUT_MS=250
RPC_BATCH_MAX_COUNT=1
RPC_READ_RETRIES=3
RPC_READ_RETRY_BASE_MS=500
RPC_TX_WAIT_RETRIES=5
RPC_TX_WAIT_RETRY_BASE_MS=1000
DAIO_DEPLOYMENT_FILE=sepolia.json
# Alternative to ./.deployments/sepolia.json:
# DAIO_DEPLOYMENT_JSON_B64=

# Public Sepolia deployment metadata. Runtime reads ./.deployments/sepolia.json;
# these variables are recorded here for operators and downstream services.
DAIO_CHAIN_ID=11155111
DAIO_CORE_ADDRESS=0xb61D8921B8E310D06dD38C913e43928780830B56
DAIO_PAYMENT_ROUTER_ADDRESS=0xe90dd5A9C6962b6308d8a46422eF8bCE32D7E063
DAIO_USDAIO_ADDRESS=0xbfd961809993e88D34235eDB0bCE1cD13a3ebAac
DAIO_STAKE_VAULT_ADDRESS=0x263091C8A7B28E5f0F71C3AE8F60823B0DcC8504
DAIO_REVIEWER_REGISTRY_ADDRESS=0xE30531Df811b06d7D4eA6a799810112aE75635BE
DAIO_ASSIGNMENT_MANAGER_ADDRESS=0x96E8D837978632D75Eb8eA242afD25B7eBf83FC8
DAIO_CONSENSUS_SCORING_ADDRESS=0xDd9dEd9e8a6b68cD1759299ce8EcD3b87577FdfA
DAIO_SETTLEMENT_ADDRESS=0xB395CBBE231974167bB3d9B7e212C594f6932523
DAIO_REPUTATION_LEDGER_ADDRESS=0x9685500168e6C5D60f3f060A49DE6F57F9AC1E9A
DAIO_ROUND_LEDGER_ADDRESS=0x6085A3371A420e5397E7edb34Dde0373BA5d00aE
DAIO_COMMIT_REVEAL_MANAGER_ADDRESS=0x29c3E89D3D3e198F8e62ead7A39F24375EC0A647
DAIO_PRIORITY_QUEUE_ADDRESS=0x8BDEA183c664E11c39Af5eF7948CE8cb46751117
DAIO_FRAIN_VRF_VERIFIER_ADDRESS=0xdf50FA950b5Afd2D551D0D5CCbA88b8aE77c5786
DAIO_VRF_COORDINATOR_ADDRESS=0x4040e3387115b81216301858168C6854038E5D28
DAIO_ACCEPTED_TOKEN_REGISTRY_ADDRESS=0x98d00bc8Ddde42dfE4F3BA7fbAd23d6880c0c19d
DAIO_ENS_VERIFIER_ADDRESS=0xEf175ad939f9bDDe284d41b779ccc13b1377530f
DAIO_ERC8004_ADAPTER_ADDRESS=0x4CD72D5817b654A76e4000F1f84dC1A128Ac3649
DAIO_UNISWAP_V4_SWAP_ADAPTER_ADDRESS=0xDa724BA5Eba473De3dc7dd38A686003637d694B3
DAIO_AUTO_CONVERT_HOOK_ADDRESS=0xc34f2d0a9D6c768479682d8c3aB114a4a4e00040

# Public Sepolia external integrations.
SEPOLIA_ENS_REGISTRY_ADDRESS=0x00000000000C2E074eC69A0dFb2997BA6C7d2e1e
SEPOLIA_ERC8004_IDENTITY_REGISTRY_ADDRESS=0x8004A818BFB912233c491871b3d84c89A494BD9e
SEPOLIA_ERC8004_REPUTATION_REGISTRY_ADDRESS=0x8004B663056A597Dffe9eCcC1965A193B7388713
SEPOLIA_UNISWAP_V4_POOL_MANAGER_ADDRESS=0xE03A1074c86CFeDd5C142C4F04F1a1536e203543
SEPOLIA_UNISWAP_V4_POSITION_MANAGER_ADDRESS=0x429ba70129df741B2Ca2a85BC3A2a3328e5c09b4
SEPOLIA_UNISWAP_UNIVERSAL_ROUTER_ADDRESS=0x3A9D48AB9751398BbFa63ad67599Bb04e4BdF98b
SEPOLIA_PERMIT2_ADDRESS=0x000000000022D473030F116dDEE9F6B43aC78BA3

# Content service
CONTENT_SERVICE_BIND=127.0.0.1
CONTENT_SERVICE_PORT=18002
CONTENT_SERVICE_HOST=127.0.0.1
CONTENT_DB_PATH=./.data/content.sqlite
CONTENT_SERVICE_LOG=0

# Browser access. Default permits local frontends and public callers; set to a
# comma-separated allowlist such as http://localhost:3000,https://app.example.
CORS_ALLOW_ORIGIN=*
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Content-Type,Authorization,X-Requested-With,X-Filename
CORS_EXPOSE_HEADERS=Content-Length,Content-Type
CORS_MAX_AGE=86400
CORS_ALLOW_CREDENTIALS=false

# Relayer pays gas for signed requester intents. Keep this private.
CONTENT_RELAYER_PRIVATE_KEY=
CONTENT_RELAYER_CONFIRMATIONS=1
CONTENT_REQUIRE_AGENT_SIGNATURES=true

# MarkItDown conversion service
MARKITDOWN_BIND=127.0.0.1
MARKITDOWN_PORT=18003
MARKITDOWN_MAX_UPLOAD_BYTES=52428800
MARKITDOWN_ENABLE_PLUGINS=false

# LLM defaults used by local scripts/E2E. Per-agent production compose uses
# .env.agent_N files; keep the same values there unless operators differ.
LLM_BASE_URL=http://100.94.8.47:8000/v1
LLM_MODEL=gpt-oss-120b
LLM_TIMEOUT_MS=120000
LLM_MAX_TOKENS=8192
LLM_PROPOSAL_CHAR_BUDGET=350000
LLM_REASONING_EFFORT=low

# Agent runtime safety defaults. Per-agent production compose uses
# .env.agent_N files and docker-compose keeper overrides.
DAIO_DOCUMENT_WAIT_MS=300000
DAIO_DOCUMENT_RETRY_INITIAL_MS=1000
DAIO_DOCUMENT_RETRY_MAX_MS=10000
DAIO_DOCUMENT_RECHECK_MS=10000
DAIO_DOCUMENT_PHASE_DEADLINE_BUFFER_MS=180000
DAIO_FALLBACK_PHASE_TIMEOUT_MS=600000
DAIO_EVENT_LOOKBACK_BLOCKS=7200
DAIO_EVENT_REORG_DEPTH_BLOCKS=12
DAIO_KEEPER_RECONCILE_INTERVAL_MS=10000
DAIO_KEEPER_SYNC_ACTIVE_REQUESTS=true
DAIO_KEEPER_SYNC_MAX_PER_TICK=8
# Optional dedicated gas wallet for keeper-only startNextRequest/syncRequest txs.
# Review/audit commit-reveal still uses each AGENT_PRIVATE_KEY because the
# reviewer address must be msg.sender.
DAIO_KEEPER_PRIVATE_KEY=
DAIO_START_NEXT_REQUEST_GAS_FLOOR=300000
DAIO_SYNC_REQUEST_GAS_FLOOR=2000000

# E2E
# local: deploy a fresh local stack. sepolia-fork: fork Sepolia and use
# ./.deployments/sepolia.json addresses without replacing deployed contracts.
E2E_CHAIN_MODE=sepolia-fork
# E2E_FORK_RPC_URL can override RPC_URL for `npm run e2e:sepolia-fork`.
E2E_FORK_RPC_URL=https://sepolia.drpc.org
E2E_SEPOLIA_FORK_BLOCK=
E2E_SEPOLIA_DEPLOYMENT_PATH=.deployments/sepolia.json
E2E_FORK_DISABLE_IDENTITY_MODULES=true
E2E_FORK_CONFIGURE_FAST_TIER=true
E2E_HARDHAT_SILENT=true
E2E_AGENT_COUNT=5
E2E_QUORUM=4
E2E_REQUEST_COUNT=2
E2E_MAX_ACTIVE_REQUESTS=2
# Reliable full E2E defaults for the current five-agent profile.
E2E_REVIEW_VRF_DIFFICULTY=10000
E2E_AUDIT_VRF_DIFFICULTY=10000
E2E_AUDIT_TARGET_LIMIT=3
E2E_AGENT_FALLBACK_REVIEW_VRF_DIFFICULTY=1
E2E_AGENT_FALLBACK_AUDIT_VRF_DIFFICULTY=1
E2E_AGENT_FALLBACK_AUDIT_TARGET_LIMIT=1
E2E_AGENT_AUTO_START_REQUESTS=false
E2E_LLM_TIMEOUT_MS=300000
E2E_LLM_MAX_TOKENS=8192
E2E_LLM_PROPOSAL_CHAR_BUDGET=350000

# Gas limits used by E2E agents. When set, agents skip expensive gas estimation.
DAIO_REVIEW_COMMIT_GAS_FLOOR=7000000
DAIO_REVIEW_REVEAL_GAS_FLOOR=2000000
DAIO_AUDIT_COMMIT_GAS_FLOOR=12000000
DAIO_AUDIT_REVEAL_GAS_FLOOR=12000000
