# Production Sepolia chain / deployment
RPC_URL=
DAIO_DEPLOYMENT_FILE=sepolia.json
# Alternative to ./.deployments/sepolia.json:
# DAIO_DEPLOYMENT_JSON_B64=

# Public Sepolia deployment metadata. Runtime reads ./.deployments/sepolia.json;
# these variables are recorded here for operators and downstream services.
DAIO_CHAIN_ID=11155111
DAIO_CORE_ADDRESS=0xb61D8921B8E310D06dD38C913e43928780830B56
DAIO_PAYMENT_ROUTER_ADDRESS=0xe90dd5A9C6962b6308d8a46422eF8bCE32D7E063
