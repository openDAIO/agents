# LLM (OpenAI-compatible)
LLM_BASE_URL=http://59.12.201.156:18001/v1
LLM_MODEL=gpt-oss-120b
LLM_TIMEOUT_MS=120000
LLM_MAX_TOKENS=8192
LLM_PROPOSAL_CHAR_BUDGET=350000
LLM_REASONING_EFFORT=low

# Content service
CONTENT_SERVICE_BIND=127.0.0.1
CONTENT_SERVICE_PORT=18002
CONTENT_SERVICE_HOST=127.0.0.1
CONTENT_DB_PATH=./.data/content.sqlite

# Relayer pays gas for signed requester intents. Keep this private.
CONTENT_RELAYER_PRIVATE_KEY=
CONTENT_RELAYER_CONFIRMATIONS=1

# MarkItDown conversion service
MARKITDOWN_BIND=127.0.0.1
MARKITDOWN_PORT=18003
MARKITDOWN_MAX_UPLOAD_BYTES=52428800
MARKITDOWN_ENABLE_PLUGINS=false

# Agent runtime
AGENT_STATE_KEY=
AGENT_AUTO_REGISTER=true
# Local fallback only. Agents prefer DAIOCore's on-chain storage config.
DAIO_REVIEW_ELECTION_DIFFICULTY=8000
DAIO_AUDIT_ELECTION_DIFFICULTY=10000
DAIO_AUDIT_TARGET_LIMIT=2
DAIO_AUTO_START_REQUESTS=true
DAIO_START_REQUESTS_MAX_PER_TICK=2
DAIO_START_REQUESTS_MIN_INTERVAL_MS=1000
DAIO_START_REQUESTS_JITTER_MS=250

# Five reviewer nodes. Each reviewer needs a funded Sepolia tx signer and a
# separate secp256k1 VRF private key. VRF public keys are derived at boot and
# registered on-chain by AGENT_AUTO_REGISTER.
AGENT_1_PRIVATE_KEY=
AGENT_1_VRF_PRIVATE_KEY=
AGENT_1_ID=1001
AGENT_1_ENS_NAME=reviewer-1.daio.eth

AGENT_2_PRIVATE_KEY=
AGENT_2_VRF_PRIVATE_KEY=
AGENT_2_ID=1002
AGENT_2_ENS_NAME=reviewer-2.daio.eth

AGENT_3_PRIVATE_KEY=
AGENT_3_VRF_PRIVATE_KEY=
AGENT_3_ID=1003
AGENT_3_ENS_NAME=reviewer-3.daio.eth

AGENT_4_PRIVATE_KEY=
AGENT_4_VRF_PRIVATE_KEY=
AGENT_4_ID=1004
AGENT_4_ENS_NAME=reviewer-4.daio.eth

AGENT_5_PRIVATE_KEY=
AGENT_5_VRF_PRIVATE_KEY=
AGENT_5_ID=1005
AGENT_5_ENS_NAME=reviewer-5.daio.eth
